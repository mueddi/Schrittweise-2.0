# ---- Schrittweise Backend – Beispiel-Konfiguration ----
# Kopiere diese Datei nach .env und trage echte Werte ein.
# .env wird NIE committet (steht in .gitignore).

# Anthropic API-Key (Pflicht fuer den Tutor-Chat)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelle: Standard fuer Tutoring-Turns, "smart" nur fuer komplexe Faelle
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# JWT: langer zufaelliger Wert. Erzeugen z.B. mit: openssl rand -hex 32
JWT_SECRET=change-me-bitte-einen-langen-zufallswert-einsetzen
JWT_EXPIRE_MINUTES=43200

# Datenbank – SQLite fuer den Start. Fuer Postgres spaeter einfach umstellen:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/schrittweise
DATABASE_URL=sqlite:///./schrittweise.db

# CORS: erlaubte Frontend-Origins (Komma-getrennt)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Magic-Link: ohne SMTP wird der Link im Dev-Modus direkt zurueckgegeben,
# damit du dich ohne Mailserver einloggen kannst.
MAGIC_LINK_DEV_RETURN=true
FRONTEND_BASE_URL=http://localhost:5173

# Optional: echter Mailversand (wenn gesetzt, wird der Link gemailt statt zurueckgegeben)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=Schrittweise <no-reply@schrittweise.ch>

# Gratis-Kontingent (Aufgaben pro Monat)
FREE_MONTHLY_QUOTA=5
